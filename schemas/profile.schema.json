{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/thinking-partner/profile.schema.json",
  "title": "Thinking Profile",
  "description": "The user's current, explicitly confirmed collection of revisable long-term thinking models.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "profile_revision",
    "updated_at",
    "collaboration_preferences",
    "definitions",
    "working_models",
    "recurring_inquiry_moves",
    "unresolved_tensions",
    "long_term_questions"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "profile_revision": { "type": "integer", "minimum": 0 },
    "updated_at": { "type": "string", "format": "date-time" },
    "collaboration_preferences": {
      "type": "array",
      "items": { "$ref": "#/$defs/collaborationPreference" }
    },
    "definitions": {
      "type": "array",
      "items": { "$ref": "#/$defs/definition" }
    },
    "working_models": {
      "type": "array",
      "items": { "$ref": "#/$defs/workingModel" }
    },
    "recurring_inquiry_moves": {
      "type": "array",
      "items": { "$ref": "#/$defs/recurringInquiryMove" }
    },
    "unresolved_tensions": {
      "type": "array",
      "items": { "$ref": "#/$defs/unresolvedTension" }
    },
    "long_term_questions": {
      "type": "array",
      "items": { "$ref": "#/$defs/longTermQuestion" }
    }
  },
  "$defs": {
    "status": {
      "type": "string",
      "enum": ["observed", "proposed", "confirmed", "retired"]
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "baseEntry": {
      "type": "object",
      "required": ["id", "status", "evidence"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "status": { "$ref": "#/$defs/status" },
        "evidence": { "$ref": "#/$defs/evidence" }
      }
    },
    "collaborationPreference": {
      "allOf": [
        { "$ref": "#/$defs/baseEntry" },
        {
          "type": "object",
          "required": ["statement"],
          "properties": {
            "statement": { "type": "string", "minLength": 1 }
          }
        }
      ],
      "unevaluatedProperties": false
    },
    "definition": {
      "allOf": [
        { "$ref": "#/$defs/baseEntry" },
        {
          "type": "object",
          "required": ["term", "current_definition"],
          "properties": {
            "term": { "type": "string", "minLength": 1 },
            "current_definition": { "type": "string", "minLength": 1 },
            "supersedes": { "type": ["string", "null"] }
          }
        }
      ],
      "unevaluatedProperties": false
    },
    "workingModel": {
      "allOf": [
        { "$ref": "#/$defs/baseEntry" },
        {
          "type": "object",
          "required": ["label", "claim", "scope"],
          "properties": {
            "label": { "type": "string", "minLength": 1 },
            "claim": { "type": "string", "minLength": 1 },
            "scope": { "type": "string", "minLength": 1 },
            "supporting_evidence": {
              "type": "array",
              "items": { "type": "string" },
              "uniqueItems": true
            },
            "counter_evidence": {
              "type": "array",
              "items": { "type": "string" },
              "uniqueItems": true
            },
            "supersedes": { "type": ["string", "null"] }
          }
        }
      ],
      "unevaluatedProperties": false
    },
    "recurringInquiryMove": {
      "allOf": [
        { "$ref": "#/$defs/baseEntry" },
        {
          "type": "object",
          "required": ["observation"],
          "properties": {
            "observation": { "type": "string", "minLength": 1 }
          }
        }
      ],
      "unevaluatedProperties": false
    },
    "unresolvedTension": {
      "allOf": [
        { "$ref": "#/$defs/baseEntry" },
        {
          "type": "object",
          "required": ["poles", "current_formulation"],
          "properties": {
            "poles": {
              "type": "array",
              "minItems": 2,
              "items": { "type": "string", "minLength": 1 }
            },
            "current_formulation": { "type": "string", "minLength": 1 }
          }
        }
      ],
      "unevaluatedProperties": false
    },
    "longTermQuestion": {
      "allOf": [
        { "$ref": "#/$defs/baseEntry" },
        {
          "type": "object",
          "required": ["question", "why_it_matters"],
          "properties": {
            "question": { "type": "string", "minLength": 1 },
            "why_it_matters": { "type": "string", "minLength": 1 }
          }
        }
      ],
      "unevaluatedProperties": false
    }
  }
}

