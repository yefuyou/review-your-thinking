{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/thinking-partner/patch.schema.json",
  "title": "Thinking Profile Patch",
  "description": "A reviewable set of proposed changes to a Thinking Profile.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "patch_id",
    "created_at",
    "base_profile_revision",
    "status",
    "changes"
  ],
  "properties": {
    "patch_id": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "format": "date-time" },
    "base_profile_revision": { "type": "integer", "minimum": 0 },
    "status": {
      "type": "string",
      "enum": ["pending", "confirmed", "rejected", "applied"]
    },
    "applied_at": { "type": "string", "format": "date-time" },
    "changes": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/change" }
    }
  },
  "$defs": {
    "change": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "operation",
        "target_section",
        "target_id",
        "proposed_value",
        "evidence",
        "reason"
      ],
      "properties": {
        "operation": {
          "type": "string",
          "enum": ["add", "update", "retire", "delete"]
        },
        "target_section": {
          "type": "string",
          "enum": [
            "collaboration_preferences",
            "definitions",
            "working_models",
            "recurring_inquiry_moves",
            "unresolved_tensions",
            "long_term_questions"
          ]
        },
        "target_id": { "type": "string", "minLength": 1 },
        "proposed_value": {},
        "evidence": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "reason": { "type": "string", "minLength": 1 }
      }
    }
  }
}

