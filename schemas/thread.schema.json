{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/review-your-thinking/thread.schema.json",
  "title": "Thinking Thread",
  "description": "One concrete line of inquiry that can continue across sessions.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "title",
    "status",
    "current_question",
    "current_framing",
    "assumptions",
    "tensions",
    "unknowns",
    "next_probe",
    "linked_models",
    "session_refs"
  ],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "status": {
      "type": "string",
      "enum": ["active", "paused", "closed"]
    },
    "current_question": { "type": "string", "minLength": 1 },
    "current_framing": { "type": "string", "minLength": 1 },
    "assumptions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "tensions": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "unknowns": {
      "type": "array",
      "items": { "type": "string" }
    },
    "next_probe": { "type": "string", "minLength": 1 },
    "linked_models": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "session_refs": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    }
  }
}
